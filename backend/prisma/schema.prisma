// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  SUPPORT
  SALES
  USER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum TicketType {
  CALL
  SUPPORT
  SALES
  FIELD
  OTHER
}

enum FormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  SHORT_TEXT
  PARAGRAPH
  MULTIPLE_CHOICE
  CHECKBOXES
  DROPDOWN
  NUMBER
  DATE
  TIME
  FILE_UPLOAD
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  RETIRED
}

enum LicenceStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

model Tenant {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  isActive       Boolean          @default(true)
  plan           String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  settings       TenantSettings?
  ticketSettings TicketSettings?
  users          User[]
  companies      Company[]
  contacts       Contact[]
  contactPhones  ContactPhone[]
  tickets        Ticket[]
  ticketComments TicketComment[]
  ticketTasks    TicketTask[]
  tags           Tag[]
  ticketTags     TicketTag[]
  auditLogs      AuditLog[]
  forms          Form[]
  devices        Device[]
  licences       Licence[]
  licenceEvents  LicenceEvent[]
  licenceNotificationLogs LicenceNotificationLog[]
  domains        TenantDomain[]
}

model TenantDomain {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain     String
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([tenantId, domain])
}

model TenantSettings {
  id                      String   @id @default(cuid())
  tenantId                String   @unique
  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  data                    Json?    @default("{}")
  logoUrl                 String?
  brandName               String?
  primaryColour           String?
  emailSignature          String?
  emailFromName           String?
  emailFromAddress        String?
  emailProvider           String?  // 'GOOGLE' | 'M365' – za SMTP
  emailPassword           String?  // App password / lozinka za slanje (nikad u odgovoru)
  notificationsDaysBefore Json?
  reportSchedule          String?  // 'none' | 'daily' | 'weekly' – automatski izveštaj (legacy)
  reportEmails            Json?    // string[] – primaoci izveštaja (legacy)
  reportEmailConfigs       Json?    // ReportEmailConfig[] – per-email: period, tip izveštaja, kompanija, uređaji
  jwtAccessTtlMinutes     Int?     @default(10080)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model TicketSettings {
  id                     String         @id @default(cuid())
  tenantId               String         @unique
  tenant                 Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultStatus          TicketStatus   @default(OPEN)
  defaultType            TicketType     @default(CALL)
  defaultPriority        TicketPriority? @default(MEDIUM)
  allowedStatuses        Json           @default("[\"OPEN\",\"IN_PROGRESS\",\"DONE\"]")
  allowedTypes           Json           @default("[\"CALL\",\"SUPPORT\",\"SALES\",\"FIELD\",\"OTHER\"]")
  allowedPriorities      Json           @default("[\"LOW\",\"MEDIUM\",\"HIGH\"]")
  autoInProgressOnAssign Boolean        @default(true)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

model User {
  id                String          @id @default(cuid())
  email             String
  displayName       String?
  passwordHash      String
  role              UserRole
  isActive          Boolean         @default(true)
  isPlatformAdmin   Boolean         @default(false)
  receiveLicenceExpiryEmails Boolean @default(false)
  tenantId          String?
  companyId         String?
  company           Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  tenant            Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  assignedTickets   Ticket[]        @relation("AssignedTo")
  createdTickets    Ticket[]        @relation("TicketCreator")
  ticketComments    TicketComment[]
  createdForms      Form[]          @relation("FormCreator")
  formSubmissions   FormSubmission[] @relation("SubmissionAuthor")
  refreshTokens     RefreshToken[]
  passwordResets   PasswordResetToken[]

  @@unique([tenantId, email])
}

model Company {
  id         String    @id @default(cuid())
  key        String?  // display ID e.g. C-000001
  name       String
  city       String?
  postalCode String?
  address    String?
  pib        String?
  mb         String?
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  contacts   Contact[]
  tickets    Ticket[]
  devices    Device[]
  licences   Licence[]
  users      User[]
  // Dodaci (add-ons) – lampice aktivno/neaktivno
  addOnViewInvoicesAllDevices Boolean @default(false)
  addOnLastInvoice            Boolean @default(false)
  addOnAlarmsEmail            Boolean @default(false)
  addOnCashInvoice            Boolean @default(false)
  addOnApiAccess              Boolean @default(false)
  addOnReportScheduling       Boolean @default(false)

  @@unique([tenantId, key])
}

model Contact {
  id        String         @id @default(cuid())
  name      String
  email     String?
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  phones    ContactPhone[]
  tickets   Ticket[]
}

model ContactPhone {
  id              String   @id @default(cuid())
  phoneRaw        String   @default("")
  phoneNormalised String
  isPrimary       Boolean  @default(false)
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, phoneNormalised])
}

model Ticket {
  id                   String          @id @default(cuid())
  key                  String
  title                String
  description          String?
  status               TicketStatus    @default(OPEN)
  type                 TicketType      @default(OTHER)
  tenantId             String
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId            String?
  company              Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId            String?
  contact              Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assigneeId           String?
  assignee             User?           @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdByUserId      String?
  createdBy            User?           @relation("TicketCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  phoneRaw             String?
  contactName          String?
  callOccurredAt       DateTime?
  callDurationMinutes  Int?
  reportedBy           String?         // Ko je prijavio (manual ticket)
  putIAngazovanje      Json?          // Put i angažovanje – array of strings (manual ticket)
  tokPrijave           String?        // Tok prijave (manual ticket)
  zakljucak            String?        // Zaključak (manual ticket)
  potpisOvlascenogLica  String?        // Potpis ovlašćenog lica (manual ticket)
  ticketDate           DateTime?      // Datum na formi (manual ticket)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  comments             TicketComment[]
  tasks                TicketTask[]
  ticketTags           TicketTag[]

  @@unique([tenantId, key])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, callOccurredAt])
}

model TicketComment {
  id        String   @id @default(cuid())
  tenantId  String
  ticketId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId, ticketId, createdAt])
}

model TicketTask {
  id        String   @id @default(cuid())
  tenantId  String
  ticketId  String
  title     String
  isDone    Boolean  @default(false)
  orderNo   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([tenantId, ticketId, orderNo])
}

model Tag {
  id        String      @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime    @default(now())
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketTags TicketTag[]

  @@unique([tenantId, name])
}

model TicketTag {
  id        String   @id @default(cuid())
  tenantId  String
  ticketId  String
  tagId     String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tenantId, ticketId, tagId])
  @@index([tenantId, ticketId])
}

model AuditLog {
  id               String   @id @default(cuid())
  tenantId         String?
  tenant           Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUserId      String?
  actingAsUserId   String?
  isImpersonation  Boolean  @default(false)
  action           String
  entityType       String?
  entityId         String?
  metadata         Json?
  ip               String?
  userAgent        String?
  requestId        String?
  createdAt        DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
}

model RefreshToken {
  id         String    @id @default(cuid())
  tenantId   String?
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  tenantId   String?
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, expiresAt])
}

model Form {
  id               String         @id @default(cuid())
  key              String?        // display ID e.g. F-000001
  tenantId         String
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  status           FormStatus     @default(DRAFT)
  isActive         Boolean        @default(true)
  createdByUserId  String
  createdBy        User           @relation("FormCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  publishedAt      DateTime?
  publicSlug       String?
  questions        FormQuestion[]
  submissions      FormSubmission[]

  @@index([tenantId, status, updatedAt])
  @@unique([tenantId, key])
  @@unique([tenantId, publicSlug])
}

model FormQuestion {
  id          String              @id @default(cuid())
  tenantId    String
  formId      String
  form        Form                @relation(fields: [formId], references: [id], onDelete: Cascade)
  type        QuestionType
  title       String
  helpText    String?
  isRequired  Boolean             @default(false)
  orderNo     Int                 @default(0)
  settings    Json?
  isArchived  Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  options     FormQuestionOption[]
  answers     FormAnswer[]

  @@index([tenantId, formId, orderNo])
}

model FormQuestionOption {
  id         String       @id @default(cuid())
  tenantId   String
  questionId String
  question   FormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String
  value      String?
  orderNo    Int          @default(0)

  @@index([tenantId, questionId, orderNo])
}

model FormSubmission {
  id                String       @id @default(cuid())
  key               String?      // display ID e.g. Ta-000001
  tenantId          String
  formId            String
  form              Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  submittedByUserId String?
  submittedBy       User?        @relation("SubmissionAuthor", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime     @default(now())
  source            String?
  metadata          Json?
  answers           FormAnswer[]

  @@index([tenantId, formId, createdAt])
  @@unique([tenantId, key])
}

model FormAnswer {
  id           String         @id @default(cuid())
  tenantId     String
  submissionId String
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId  String
  question     FormQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  valueText    String?
  valueNumber  Float?
  valueDate    DateTime?
  valueJson    Json?
  createdAt    DateTime       @default(now())

  @@unique([tenantId, submissionId, questionId])
  @@index([tenantId, questionId])
}

model Device {
  id         String       @id @default(cuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId  String?
  company    Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name       String?
  model      String?
  serialNo   String?
  status     DeviceStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  licences   Licence[]
  // Meta / podešavanja uređaja
  testDevice           Boolean @default(false)
  dpu                  Boolean @default(false)
  sufEnvironment       String? // produkciono, test, itd.
  eFakturaEnvironment   String?
  paymentType          String?
  accountSync          String? // isključena, uključena
  teronPaymentGateway  Boolean @default(false)
  mdmProfileName       String?

  @@index([tenantId, companyId, updatedAt])
  @@unique([tenantId, serialNo])
}

model Licence {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deviceId    String?
  device      Device?        @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  productName String
  licenceKey  String?
  validFrom   DateTime?
  validTo     DateTime
  status      LicenceStatus  @default(ACTIVE)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  events      LicenceEvent[]
  notificationLogs LicenceNotificationLog[]

  @@index([tenantId, validTo])
  @@index([tenantId, companyId, validTo])
}

model LicenceEvent {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  licenceId      String
  licence        Licence  @relation(fields: [licenceId], references: [id], onDelete: Cascade)
  type           String
  note           String?
  createdByUserId String?
  createdAt      DateTime @default(now())

  @@index([tenantId, licenceId, createdAt])
}

model LicenceNotificationLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  licenceId  String
  licence    Licence  @relation(fields: [licenceId], references: [id], onDelete: Cascade)
  daysBefore Int
  triggerDate DateTime
  recipient  String?
  status     String
  error      String?
  createdAt  DateTime @default(now())

  @@unique([tenantId, licenceId, daysBefore, triggerDate])
  @@index([tenantId, createdAt])
}
